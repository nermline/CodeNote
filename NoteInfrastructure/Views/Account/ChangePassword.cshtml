@model NoteInfrastructure.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Зміна пароля";
}

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="bi bi-key"></i> Зміна пароля</h1>
        <div class="breadcrumb-path">
            <a asp-controller="Folders" asp-action="Index">Головна</a> /
            <a asp-action="Profile">Профіль</a> / Зміна пароля
        </div>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header d-flex align-items-center gap-2" style="color:var(--text-primary, inherit)">
                <i class="bi bi-shield-lock text-primary fs-5"></i>
                <strong>Введіть дані для зміни пароля</strong>
            </div>
            <div class="card-body">

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"
                     style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                <form asp-action="ChangePassword" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="CurrentPassword" class="form-label fw-semibold"></label>
                        <input asp-for="CurrentPassword" class="form-control" type="password"
                               autocomplete="current-password" />
                        <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                    </div>

                    <hr />

                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label fw-semibold"></label>
                        <input asp-for="NewPassword" class="form-control" type="password"
                               autocomplete="new-password" id="newPasswordInput" />
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                        <div class="mt-1" style="font-size:0.75rem; color:var(--text-muted);">
                            <i class="bi bi-info-circle me-1"></i>Мінімум 6 символів, щонайменше одна цифра
                        </div>
                        
                        <div class="progress mt-2" style="height:5px; display:none" id="strengthBar">
                            <div class="progress-bar" id="strengthFill" style="width:0%"></div>
                        </div>
                        <div class="small mt-1" id="strengthLabel" style="display:none"></div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                        <input asp-for="ConfirmPassword" class="form-control" type="password"
                               autocomplete="new-password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-floppy me-1"></i> Змінити пароль
                        </button>
                        <a asp-action="Profile" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i> Скасувати
                        </a>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
    (function () {
        const input = document.getElementById('newPasswordInput');
        const bar   = document.getElementById('strengthBar');
        const fill  = document.getElementById('strengthFill');
        const label = document.getElementById('strengthLabel');

        if (!input) return;

        input.addEventListener('input', function () {
            const val = this.value;
            if (!val) { bar.style.display = 'none'; label.style.display = 'none'; return; }

            bar.style.display = 'block';
            label.style.display = 'block';

            let score = 0;
            if (val.length >= 6)  score++;
            if (val.length >= 10) score++;
            if (/[0-9]/.test(val)) score++;
            if (/[A-Z]/.test(val)) score++;
            if (/[^a-zA-Z0-9]/.test(val)) score++;

            const levels = [
                { pct: 20,  cls: 'bg-danger',  text: 'Дуже слабкий' },
                { pct: 40,  cls: 'bg-danger',  text: 'Слабкий'      },
                { pct: 60,  cls: 'bg-warning', text: 'Середній'     },
                { pct: 80,  cls: 'bg-info',    text: 'Сильний'      },
                { pct: 100, cls: 'bg-success', text: 'Дуже сильний' },
            ];
            const lvl = levels[Math.max(0, score - 1)];
            fill.style.width  = lvl.pct + '%';
            fill.className    = 'progress-bar ' + lvl.cls;
            label.textContent = lvl.text;
            label.className   = 'small mt-1 ' + (score >= 3 ? 'text-success' : 'text-warning');
        });
    })();
    </script>
}
