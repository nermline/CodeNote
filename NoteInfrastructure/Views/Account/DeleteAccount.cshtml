@{
    ViewData["Title"] = "Видалення акаунту";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white d-flex align-items-center gap-2">
                <i class="bi bi-exclamation-triangle-fill fs-5"></i>
                <strong>Видалення акаунту</strong>
            </div>
            <div class="card-body">

                <p class="text-danger fw-semibold">
                    <i class="bi bi-exclamation-circle me-1"></i>
                    Це незворотна дія! Усі ваші дані (папки, файли, теги) будуть видалені.
                </p>

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"
                     style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                <form asp-action="DeleteAccountConfirmed" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-4">
                        <label class="form-label fw-semibold">
                            Для підтвердження введіть слово <code>ВИДАЛИТИ</code>:
                        </label>
                        <input type="text" name="confirmation" class="form-control"
                               placeholder="ВИДАЛИТИ" autocomplete="off" />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash me-1"></i> Видалити назавжди
                        </button>
                        <a asp-action="Profile" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i> Скасувати
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
