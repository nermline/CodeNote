@model NoteDomain.Model.File

@{
    ViewData["Title"] = Model.Name;

    string BuildFullPath(NoteDomain.Model.Folder? folder, string fileName)
    {
        if (folder == null) return "~/" + fileName;
        var parts = new System.Collections.Generic.List<string>();
        var cur = folder;
        while (cur != null) { parts.Insert(0, cur.Name); cur = cur.Parentfolder; }
        return "~/" + string.Join("/", parts) + "/" + fileName;
    }

    string fullPath = BuildFullPath(Model.Folder, Model.Name);
}

<div class="page-header">
    <div class="d-flex align-items-center gap-3 flex-wrap">
        @if (Model.Folder != null)
        {
            <a asp-controller="Folders" asp-action="Details" asp-route-id="@Model.Folderid" class="back-btn">
                <i class="bi bi-arrow-left"></i> @Model.Folder.Name
            </a>
        }
        else
        {
            <a asp-controller="Folders" asp-action="Index" class="back-btn">
                <i class="bi bi-arrow-left"></i> Каталоги
            </a>
        }
        <div class="editor-tab">
            <i class="bi bi-file-earmark-code"></i>
            @Model.Name
            <span class="tab-close ms-1"><i class="bi bi-x"></i></span>
        </div>
        <span class="breadcrumb-path">
            <i class="bi bi-hdd-network me-1"></i>@fullPath
        </span>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">
            <i class="bi bi-pencil-square"></i> Редагувати
        </a>
        <a asp-action="Delete" asp-route-id="@Model?.Id" class="btn btn-danger btn-icon" title="Видалити">
            <i class="bi bi-trash"></i>
        </a>
    </div>
</div>

<div class="editor-pane">
    <div class="row g-0" style="min-height:60vh;">
        
        <div class="col-md-3 editor-sidebar">
            <h6><i class="bi bi-info-circle"></i> Інспектор</h6>

            <div class="inspector-row">
                <div class="inspector-label">Назва файлу</div>
                <div class="inspector-value">@Model.Name</div>
            </div>

            <div class="inspector-row">
                <div class="inspector-label">Повний шлях</div>
                <div class="inspector-value" style="font-size:0.78rem; word-break:break-all;">@fullPath</div>
            </div>

            <div class="inspector-row">
                <div class="inspector-label">Опис</div>
                <div class="inspector-value @(string.IsNullOrEmpty(Model.Description) ? "muted" : "")">
                    @(string.IsNullOrEmpty(Model.Description) ? "// немає опису" : Model.Description)
                </div>
            </div>

            <div class="inspector-row">
                <div class="inspector-label">Створено</div>
                <div class="inspector-value" style="color:var(--accent);">
                    @(Model.Createdat.HasValue ? Model.Createdat.Value.ToString("dd.MM.yyyy HH:mm") : "—")
                </div>
            </div>

            <hr class="divider" />

            <h6><i class="bi bi-tags"></i> Теги</h6>
            <div>
                @if (Model.Tags != null && Model.Tags.Any())
                {
                    foreach (var tag in Model.Tags)
                    {
                        <span class="tag-pill me-1 mb-1">
                            <i class="bi bi-tag-fill"></i> @tag.Name
                        </span>
                    }
                }
                else
                {
                    <span class="inspector-value muted">// без тегів</span>
                }
            </div>
        </div>

        <div class="col-md-9 p-4">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div class="section-label"><i class="bi bi-git"></i> Source Control — дерево версій</div>
                <a asp-controller="Fileversions" asp-action="Create" asp-route-fileId="@Model.Id"
                   class="btn btn-sm btn-outline-success">
                    <i class="bi bi-plus-lg"></i> Новий коміт
                </a>
            </div>

            @if (Model.Fileversions != null && Model.Fileversions.Any())
            {
                <div class="commit-list">
                    @foreach (var version in Model.Fileversions)
                    {
                        <div class="commit-item">
                            <div class="d-flex align-items-center gap-3">
                                <span class="commit-hash">v@(version.Versionnumber)</span>
                                <div>
                                    <div style="font-size:0.875rem; color:var(--text-primary); font-weight:500;">
                                        @(string.IsNullOrEmpty(version.Changelog) ? "Без опису коміту" : version.Changelog)
                                    </div>
                                    <div class="commit-meta">
                                        <span style="font-family:var(--font-mono); color:var(--text-muted);">#@(version.Id)</span>
                                        @if (version.Createdat.HasValue)
                                        {
                                            <span class="ms-2">· @version.Createdat.Value.ToString("dd.MM.yyyy HH:mm")</span>
                                        }
                                    </div>
                                </div>
                            </div>
                            <div class="d-flex gap-1">
                                <a asp-controller="Fileversions" asp-action="Details" asp-route-id="@version.Id"
                                   class="btn btn-sm btn-outline-primary btn-icon" title="Переглянути код">
                                    <i class="bi bi-code-slash"></i>
                                </a>
                                <a asp-controller="Fileversions" asp-action="Edit" asp-route-id="@version.Id"
                                   class="btn btn-sm btn-warning btn-icon" title="Редагувати">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-controller="Fileversions" asp-action="Delete" asp-route-id="@version.Id"
                                   class="btn btn-sm btn-danger btn-icon" title="Видалити">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-journal-code"></i>
                    <h5>Версій ще немає</h5>
                    <p>Зробіть перший коміт, щоб почати відстежувати зміни цього файлу.</p>
                    <a asp-controller="Fileversions" asp-action="Create" asp-route-fileId="@Model.Id"
                       class="btn btn-outline-success mt-2">
                        <i class="bi bi-plus-lg"></i> Перший коміт
                    </a>
                </div>
            }
        </div>
    </div>
</div>
