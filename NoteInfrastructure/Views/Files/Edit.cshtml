@model NoteDomain.Model.File

@{
    ViewData["Title"] = "Редагування - " + Model.Name;
}

<div class="editor-pane">
    <div class="editor-header mb-4">
        <h5 class="mb-0 text-light"><i class="bi bi-gear-fill text-secondary me-2"></i>settings.json > @Model.Name</h5>
    </div>

    <form asp-action="Edit" class="px-4 pb-4 row">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <input type="hidden" asp-for="Id" />

        <div class="col-md-6">
            <div class="form-group mb-3">
                <label asp-for="Name" class="form-label text-info">"filename":</label>
                <div class="input-group">
                    <span class="input-group-text bg-dark border-secondary text-muted"><i class="bi bi-quote"></i></span>
                    <input asp-for="Name" class="form-control" />
                </div>
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Folderid" class="form-label text-info">"directory_id":</label>
                <div class="input-group">
                    <span class="input-group-text bg-dark border-secondary text-muted"><i class="bi bi-folder2"></i></span>
                    <select asp-for="Folderid" class="form-select" asp-items="ViewBag.Folderid"></select>
                </div>
                <span asp-validation-for="Folderid" class="text-danger small"></span>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="Createdat" class="form-label text-info">"created_at":</label>
                <input asp-for="Createdat" class="form-control" readonly style="opacity: 0.7;" />
                <span asp-validation-for="Createdat" class="text-danger small"></span>
            </div>
        </div>

        <div class="col-md-6 d-flex flex-column">
            <div class="form-group mb-3 flex-grow-1 d-flex flex-column">
                <label asp-for="Description" class="form-label text-info">"description":</label>
                <textarea asp-for="Description" class="form-control flex-grow-1" style="min-height: 120px; resize: none;"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>
        </div>

        <div class="col-12 mt-2">
            <div class="form-group mb-3">
                <label class="form-label text-info">"tags": [</label>
                <select name="selectedTags" class="form-select" asp-items="ViewBag.Tags" multiple="multiple" style="height: 120px;"></select>
                <label class="form-label text-info mt-1">]</label>
                <small class="d-block text-muted">// Використовуйте Ctrl (або Cmd), щоб вибрати декілька елементів масиву</small>
            </div>
        </div>

        <div class="col-12 mt-4 pt-3 border-top border-secondary text-end">
            <a asp-action="Index" class="btn btn-outline-secondary me-2"><i class="bi bi-escape"></i> Скасувати</a>
            <button type="submit" class="btn btn-primary"><i class="bi bi-floppy"></i> Зберегти (Ctrl+S)</button>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}