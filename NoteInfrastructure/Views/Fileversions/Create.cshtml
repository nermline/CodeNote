@model NoteDomain.Model.Fileversion

@{
    ViewData["Title"] = "Новий коміт";
}

<div class="page-header">
    <div class="d-flex align-items-center gap-3">
        <a asp-action="Index" class="back-btn"><i class="bi bi-arrow-left"></i> Версії</a>
        <h1 class="page-title"><i class="bi bi-plus-circle"></i> Новий коміт</h1>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-9 col-lg-7">
        <div class="form-card">
            <div class="form-card-header">
                <h5>
                    <i class="bi bi-git" style="color:var(--green)"></i>
                    Створення нової версії файлу
                </h5>
            </div>
            <div class="form-card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-8">
                            <label asp-for="Fileid" class="form-label">Файл</label>
                            <select asp-for="Fileid" class="form-select" asp-items="ViewBag.Fileid"></select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Versionnumber" class="form-label">Номер версії</label>
                            <div class="input-group">
                                <span class="input-group-text" style="font-family:var(--font-mono);">v</span>
                                <input asp-for="Versionnumber" class="form-control" style="font-family:var(--font-mono);" placeholder="1.0.0" />
                            </div>
                            <span asp-validation-for="Versionnumber" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Changelog" class="form-label">Опис змін (Changelog)</label>
                        <input asp-for="Changelog" class="form-control" placeholder="Короткий опис того, що змінено…" />
                        <span asp-validation-for="Changelog" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Content" class="form-label">
                            <i class="bi bi-code-slash me-1" style="color:var(--green)"></i>Вміст файлу
                        </label>
                        <textarea asp-for="Content" class="form-control code-area" rows="14" placeholder="// Вставте код або вміст файлу тут…"></textarea>
                        <span asp-validation-for="Content" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <hr class="divider" />
                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-action="Index" class="btn btn-outline-secondary">Скасувати</a>
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check2-circle"></i> Зберегти коміт
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
