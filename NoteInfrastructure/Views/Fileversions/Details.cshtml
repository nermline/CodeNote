@model NoteDomain.Model.Fileversion

@{
    ViewData["Title"] = "v" + Model.Versionnumber + " — " + (Model.File?.Name ?? "коміт");

    string BuildFullPath(NoteDomain.Model.Folder? folder, string fileName)
    {
        if (folder == null) return "~/" + fileName;
        var parts = new System.Collections.Generic.List<string>();
        var cur = folder;
        while (cur != null) { parts.Insert(0, cur.Name); cur = cur.Parentfolder; }
        return "~/" + string.Join("/", parts) + "/" + fileName;
    }

    string filePath = Model.File != null
        ? BuildFullPath(Model.File.Folder, Model.File.Name)
        : "~/…";
}

<div class="page-header">
    <div class="d-flex align-items-center gap-3 flex-wrap">
        @if (Model.File != null)
        {
            <a asp-controller="Files" asp-action="Details" asp-route-id="@Model.Fileid" class="back-btn">
                <i class="bi bi-arrow-left"></i> @Model.File.Name
            </a>
        }
        else
        {
            <a asp-action="Index" class="back-btn"><i class="bi bi-arrow-left"></i> Версії</a>
        }
        <div class="editor-tab">
            <i class="bi bi-git" style="color:var(--green)"></i>
            v@(Model.Versionnumber)
            <span style="color:var(--text-muted); font-size:0.75rem; margin-left:0.25rem;">(#@(Model.Id))</span>
        </div>
        <span class="breadcrumb-path">
            <i class="bi bi-hdd-network me-1"></i>@filePath
        </span>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">
            <i class="bi bi-pencil"></i> Редагувати
        </a>
        <a asp-action="Delete" asp-route-id="@Model?.Id" class="btn btn-danger btn-icon" title="Видалити">
            <i class="bi bi-trash"></i>
        </a>
    </div>
</div>

<div class="editor-pane">
    <div class="row g-0" style="min-height:55vh;">
        <!-- Meta sidebar -->
        <div class="col-md-3 editor-sidebar">
            <h6><i class="bi bi-info-circle"></i> Метадані коміту</h6>

            <div class="inspector-row">
                <div class="inspector-label">Версія</div>
                <div class="inspector-value" style="color:var(--green);">v@(Model.Versionnumber)</div>
            </div>

            <div class="inspector-row">
                <div class="inspector-label">Внутрішній ID</div>
                <div class="inspector-value" style="color:var(--accent);">#@(Model.Id)</div>
            </div>

            <div class="inspector-row">
                <div class="inspector-label">Файл</div>
                <div class="inspector-value">@(Model.File?.Name ?? "—")</div>
            </div>

            <div class="inspector-row">
                <div class="inspector-label">Шлях</div>
                <div class="inspector-value" style="font-size:0.77rem; word-break:break-all;">@filePath</div>
            </div>

            <div class="inspector-row">
                <div class="inspector-label">Дата</div>
                <div class="inspector-value" style="font-size:0.82rem;">
                    @(Model.Createdat.HasValue ? Model.Createdat.Value.ToString("dd.MM.yyyy HH:mm") : "—")
                </div>
            </div>

            <hr class="divider" />

            <h6><i class="bi bi-chat-left-text"></i> Changelog</h6>
            <div class="inspector-value @(string.IsNullOrEmpty(Model.Changelog) ? "muted" : "")"
                 style="font-family:var(--font-ui); line-height:1.5;">
                @(string.IsNullOrEmpty(Model.Changelog) ? "// без опису" : Model.Changelog)
            </div>
        </div>

        <!-- Code viewer -->
        <div class="col-md-9 p-4">
            <div class="section-label mb-3"><i class="bi bi-code-slash"></i> Вміст файлу</div>

            @if (!string.IsNullOrEmpty(Model.Content))
            {
                <div class="wysiwyg-viewer">@Html.Raw(Model.Content)</div>
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-file-earmark-text"></i>
                    <h5>Вміст порожній</h5>
                    <p>Цей коміт не містить тексту.</p>
                </div>
            }
        </div>
    </div>
</div>
