@model NoteDomain.Model.Fileversion

@{
    ViewData["Title"] = "Редагування коміту v" + Model.Versionnumber;

    string BuildFullPath(NoteDomain.Model.Folder? folder, string fileName)
    {
        if (folder == null) return "~/" + fileName;
        var parts = new System.Collections.Generic.List<string>();
        var cur = folder;
        while (cur != null) { parts.Insert(0, cur.Name); cur = cur.Parentfolder; }
        return "~/" + string.Join("/", parts) + "/" + fileName;
    }

    string filePath = Model.File != null
        ? BuildFullPath(Model.File.Folder, Model.File.Name)
        : "~/…";
}

<div class="page-header">
    <div class="d-flex align-items-center gap-3 flex-wrap">
        @if (Model.File != null)
        {
            <a asp-controller="Files" asp-action="Details" asp-route-id="@Model.Fileid" class="back-btn">
                <i class="bi bi-arrow-left"></i> @Model.File.Name
            </a>
        }
        else
        {
            <a asp-action="Index" class="back-btn"><i class="bi bi-arrow-left"></i> Версії</a>
        }
        <div class="editor-tab">
            <i class="bi bi-git" style="color:var(--green)"></i>
            v@(Model.Versionnumber)
            <span style="color:var(--text-muted); font-size:0.75rem; margin-left:0.25rem;">(#@(Model.Id))</span>
        </div>
        <span class="breadcrumb-path">
            <i class="bi bi-hdd-network me-1"></i>@filePath
        </span>
    </div>
</div>

<div class="editor-pane">
    <div class="editor-header">
        <span style="font-family:var(--font-mono); font-size:0.8125rem; color:var(--text-muted);">
            <i class="bi bi-pencil-square me-1" style="color:var(--yellow)"></i>
            Редагування версії файлу
        </span>
        <span class="badge badge-version">v@(Model.Versionnumber)</span>
    </div>

    <form asp-action="Edit" class="p-4" id="editForm">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>
        <input type="hidden" asp-for="Id" />

        <div class="row g-3 mb-3">
            <div class="col-md-4">
                <label asp-for="Versionnumber" class="form-label">
                    <i class="bi bi-bookmark me-1" style="color:var(--green)"></i>Номер версії
                </label>
                <div class="input-group">
                    <span class="input-group-text" style="font-family:var(--font-mono);">v</span>
                    <input asp-for="Versionnumber" class="form-control" style="font-family:var(--font-mono);" />
                </div>
                <span asp-validation-for="Versionnumber" class="text-danger small mt-1 d-block"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Createdat" class="form-label">
                    <i class="bi bi-clock me-1" style="color:var(--text-muted)"></i>Дата створення
                </label>
                <input asp-for="Createdat" class="form-control" readonly style="font-family:var(--font-mono);" />
            </div>
            <div class="col-md-4">
                <label asp-for="Fileid" class="form-label">
                    <i class="bi bi-file-earmark-code me-1" style="color:var(--accent)"></i>Файл
                </label>
                <select asp-for="Fileid" class="form-select" asp-items="ViewBag.Fileid"></select>
                <span asp-validation-for="Fileid" class="text-danger small mt-1 d-block"></span>
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="Changelog" class="form-label">
                <i class="bi bi-chat-left-text me-1" style="color:var(--purple)"></i>Опис змін (Changelog)
            </label>
            <input asp-for="Changelog" class="form-control"
                   placeholder="Короткий опис того, що змінено у цій версії…" />
            <span asp-validation-for="Changelog" class="text-danger small mt-1 d-block"></span>
        </div>

        <div class="mb-3">
            <div class="d-flex align-items-center justify-content-between mb-2">
                <label class="form-label mb-0">
                    <i class="bi bi-pencil-square me-1" style="color:var(--accent)"></i>Вміст файлу
                </label>
                <div class="wysiwyg-toolbar" id="wysiwygToolbar">
                    <button type="button" class="wysiwyg-btn" data-cmd="bold" title="Жирний"><i class="bi bi-type-bold"></i></button>
                    <button type="button" class="wysiwyg-btn" data-cmd="italic" title="Курсив"><i class="bi bi-type-italic"></i></button>
                    <button type="button" class="wysiwyg-btn" data-cmd="underline" title="Підкреслений"><i class="bi bi-type-underline"></i></button>
                    <button type="button" class="wysiwyg-btn" data-cmd="strikeThrough" title="Закреслений"><i class="bi bi-type-strikethrough"></i></button>
                    <div class="wysiwyg-divider"></div>
                    <button type="button" class="wysiwyg-btn" data-cmd="insertUnorderedList" title="Список"><i class="bi bi-list-ul"></i></button>
                    <button type="button" class="wysiwyg-btn" data-cmd="insertOrderedList" title="Нумерований список"><i class="bi bi-list-ol"></i></button>
                    <div class="wysiwyg-divider"></div>
                    <button type="button" class="wysiwyg-btn" data-cmd="justifyLeft" title="Ліво"><i class="bi bi-text-left"></i></button>
                    <button type="button" class="wysiwyg-btn" data-cmd="justifyCenter" title="Центр"><i class="bi bi-text-center"></i></button>
                    <button type="button" class="wysiwyg-btn" data-cmd="justifyRight" title="Право"><i class="bi bi-text-right"></i></button>
                    <div class="wysiwyg-divider"></div>
                    <button type="button" class="wysiwyg-btn" data-cmd="formatBlock" data-val="h2" title="Заголовок">H2</button>
                    <button type="button" class="wysiwyg-btn" data-cmd="formatBlock" data-val="h3" title="Підзаголовок">H3</button>
                    <button type="button" class="wysiwyg-btn" data-cmd="formatBlock" data-val="p" title="Параграф"><i class="bi bi-paragraph"></i></button>
                    <div class="wysiwyg-divider"></div>
                    <button type="button" class="wysiwyg-btn" id="insertLinkBtn" title="Вставити посилання"><i class="bi bi-link-45deg"></i></button>
                    <button type="button" class="wysiwyg-btn" data-cmd="removeFormat" title="Скинути форматування"><i class="bi bi-eraser"></i></button>
                    <div class="wysiwyg-divider"></div>
                    <button type="button" class="wysiwyg-btn" id="undoBtn" title="Відміна"><i class="bi bi-arrow-counterclockwise"></i></button>
                    <button type="button" class="wysiwyg-btn" id="redoBtn" title="Повтор"><i class="bi bi-arrow-clockwise"></i></button>
                </div>
            </div>

            <div class="wysiwyg-editor" id="wysiwygEditor" contenteditable="true"
                 data-placeholder="Введіть або вставте текст тут…"></div>
            <textarea asp-for="Content" id="contentHidden" class="d-none"></textarea>
            <span asp-validation-for="Content" class="text-danger small mt-1 d-block"></span>
            <div class="wysiwyg-footer">
                <span id="charCount" style="color:var(--text-muted); font-size:0.75rem; font-family:var(--font-mono);">0 символів</span>
            </div>
        </div>

        <hr class="divider" />
        <div class="d-flex gap-2 justify-content-end">
            @if (Model.File != null)
            {
                <a asp-controller="Files" asp-action="Details" asp-route-id="@Model.Fileid"
                   class="btn btn-outline-secondary">Скасувати</a>
            }
            else
            {
                <a asp-action="Index" class="btn btn-outline-secondary">Скасувати</a>
            }
            <button type="submit" class="btn btn-primary" id="submitBtn">
                <i class="bi bi-floppy"></i> Зберегти
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
    (function () {
        const editor    = document.getElementById('wysiwygEditor');
        const hidden    = document.getElementById('contentHidden');
        const charCount = document.getElementById('charCount');
        const toolbar   = document.getElementById('wysiwygToolbar');

        // Load existing content into the WYSIWYG editor
        const existingContent = hidden.value.trim();
        if (existingContent) {
            editor.innerHTML = existingContent;
        }

        // Sync before submit
        document.getElementById('editForm').addEventListener('submit', () => {
            hidden.value = editor.innerHTML;
        });

        function updateCount() {
            const text = editor.innerText || '';
            charCount.textContent = text.length + ' символів';
        }
        editor.addEventListener('input', updateCount);

        // Toolbar
        toolbar.addEventListener('mousedown', function (e) {
            const btn = e.target.closest('.wysiwyg-btn');
            if (!btn) return;
            e.preventDefault();
            const cmd = btn.dataset.cmd;
            const val = btn.dataset.val || null;
            if (cmd) {
                document.execCommand(cmd, false, val);
                editor.focus();
                updateActive();
            }
        });

        document.getElementById('insertLinkBtn').addEventListener('click', function () {
            const url = prompt('Введіть URL:');
            if (url) {
                document.execCommand('createLink', false, url);
                editor.querySelectorAll('a:not([target])').forEach(a => {
                    a.target = '_blank';
                    a.rel = 'noopener noreferrer';
                });
            }
            editor.focus();
        });

        document.getElementById('undoBtn').addEventListener('click', () => { document.execCommand('undo'); editor.focus(); });
        document.getElementById('redoBtn').addEventListener('click', () => { document.execCommand('redo'); editor.focus(); });

        function updateActive() {
            toolbar.querySelectorAll('[data-cmd]').forEach(btn => {
                const cmd = btn.dataset.cmd;
                if (['bold','italic','underline','strikeThrough',
                     'insertUnorderedList','insertOrderedList',
                     'justifyLeft','justifyCenter','justifyRight'].includes(cmd)) {
                    btn.classList.toggle('active', document.queryCommandState(cmd));
                }
            });
        }

        editor.addEventListener('keyup', updateActive);
        editor.addEventListener('mouseup', updateActive);
        editor.addEventListener('focus', updateActive);

        updateCount();
    })();
    </script>
}
