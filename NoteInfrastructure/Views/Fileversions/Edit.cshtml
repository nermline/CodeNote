@model NoteDomain.Model.Fileversion

@{
    ViewData["Title"] = "Редагування коміту v" + Model.Versionnumber;

    string BuildFullPath(NoteDomain.Model.Folder? folder, string fileName)
    {
        if (folder == null) return "~/" + fileName;
        var parts = new System.Collections.Generic.List<string>();
        var cur = folder;
        while (cur != null) { parts.Insert(0, cur.Name); cur = cur.Parentfolder; }
        return "~/" + string.Join("/", parts) + "/" + fileName;
    }

    string filePath = Model.File != null
        ? BuildFullPath(Model.File.Folder, Model.File.Name)
        : "~/…";
}

<div class="page-header">
    <div class="d-flex align-items-center gap-3 flex-wrap">
        @if (Model.File != null)
        {
            <a asp-controller="Files" asp-action="Details" asp-route-id="@Model.Fileid" class="back-btn">
                <i class="bi bi-arrow-left"></i> @Model.File.Name
            </a>
        }
        else
        {
            <a asp-action="Index" class="back-btn"><i class="bi bi-arrow-left"></i> Версії</a>
        }
        <div class="editor-tab">
            <i class="bi bi-git" style="color:var(--green)"></i>
            v@(Model.Versionnumber)
            <span style="color:var(--text-muted); font-size:0.75rem; margin-left:0.25rem;">(#@(Model.Id))</span>
        </div>
        <span class="breadcrumb-path">
            <i class="bi bi-hdd-network me-1"></i>@filePath
        </span>
    </div>
</div>

<div class="editor-pane">
    <div class="editor-header">
        <span style="font-family:var(--font-mono); font-size:0.8125rem; color:var(--text-muted);">
            <i class="bi bi-pencil-square me-1" style="color:var(--yellow)"></i>
            Редагування версії файлу
        </span>
        <span class="badge badge-version">v@(Model.Versionnumber)</span>
    </div>

    <form asp-action="Edit" class="p-4">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>
        <input type="hidden" asp-for="Id" />

        <div class="row g-3 mb-3">
            <div class="col-md-4">
                <label asp-for="Versionnumber" class="form-label">
                    <i class="bi bi-bookmark me-1" style="color:var(--green)"></i>Номер версії
                </label>
                <div class="input-group">
                    <span class="input-group-text" style="font-family:var(--font-mono);">v</span>
                    <input asp-for="Versionnumber" class="form-control" style="font-family:var(--font-mono);" />
                </div>
                <span asp-validation-for="Versionnumber" class="text-danger small mt-1 d-block"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Createdat" class="form-label">
                    <i class="bi bi-clock me-1" style="color:var(--text-muted)"></i>Дата створення
                </label>
                <input asp-for="Createdat" class="form-control" readonly style="font-family:var(--font-mono);" />
            </div>
            <div class="col-md-4">
                <label asp-for="Fileid" class="form-label">
                    <i class="bi bi-file-earmark-code me-1" style="color:var(--accent)"></i>Файл
                </label>
                <select asp-for="Fileid" class="form-select" asp-items="ViewBag.Fileid"></select>
                <span asp-validation-for="Fileid" class="text-danger small mt-1 d-block"></span>
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="Changelog" class="form-label">
                <i class="bi bi-chat-left-text me-1" style="color:var(--purple)"></i>Опис змін (Changelog)
            </label>
            <input asp-for="Changelog" class="form-control"
                   placeholder="Короткий опис того, що змінено у цій версії…" />
            <span asp-validation-for="Changelog" class="text-danger small mt-1 d-block"></span>
        </div>

        <div class="mb-3">
            <div class="d-flex align-items-center justify-content-between mb-2">
                <label class="form-label mb-0">
                    <i class="bi bi-code-slash me-1" style="color:var(--green)"></i>Вміст файлу
                </label>
                <div style="font-size:0.75rem; color:var(--text-muted); font-family:var(--font-mono);">
                    <span id="lineCount">1</span> рядк(ів) · Tab = 4 пробіли
                </div>
            </div>

            <div class="ide-editor-wrap">
                <div class="ide-line-numbers" id="lineNumbers">1</div>
                <textarea asp-for="Content"
                          id="ideContent"
                          class="ide-textarea"
                          spellcheck="false"
                          autocorrect="off"
                          autocapitalize="off"
                          placeholder="// Вставте або введіть код тут…"></textarea>
            </div>
            <span asp-validation-for="Content" class="text-danger small mt-1 d-block"></span>
        </div>

        <hr class="divider" />
        <div class="d-flex gap-2 justify-content-end">
            @if (Model.File != null)
            {
                <a asp-controller="Files" asp-action="Details" asp-route-id="@Model.Fileid"
                   class="btn btn-outline-secondary">Скасувати</a>
            }
            else
            {
                <a asp-action="Index" class="btn btn-outline-secondary">Скасувати</a>
            }
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-floppy"></i> Зберегти
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
    (function () {
        const textarea = document.getElementById('ideContent');
        const lineNumbers = document.getElementById('lineNumbers');
        const lineCount = document.getElementById('lineCount');

        function updateLineNumbers() {
            const lines = textarea.value.split('\n').length;
            lineCount.textContent = lines;
            let html = '';
            for (let i = 1; i <= lines; i++) html += i + '\n';
            lineNumbers.textContent = html;
        }

        function syncScroll() {
            lineNumbers.scrollTop = textarea.scrollTop;
        }

        textarea.addEventListener('keydown', function (e) {
            if (e.key === 'Tab') {
                e.preventDefault();
                const start = this.selectionStart;
                const end = this.selectionEnd;
                const spaces = '    ';
                if (start === end) {
                    this.value = this.value.substring(0, start) + spaces + this.value.substring(end);
                    this.selectionStart = this.selectionEnd = start + 4;
                } else {
                    const selected = this.value.substring(start, end);
                    const lines = selected.split('\n');
                    if (e.shiftKey) {
                        const dedented = lines.map(l => l.startsWith('    ') ? l.slice(4) : l).join('\n');
                        this.value = this.value.substring(0, start) + dedented + this.value.substring(end);
                    } else {
                        const indented = lines.map(l => spaces + l).join('\n');
                        this.value = this.value.substring(0, start) + indented + this.value.substring(end);
                    }
                }
                updateLineNumbers();
            }
        });

        textarea.addEventListener('input', updateLineNumbers);
        textarea.addEventListener('scroll', syncScroll);
        updateLineNumbers();
    })();
    </script>
}
