@model NoteDomain.Model.Folder

@{
    ViewData["Title"] = "Новий каталог";
}

<div class="page-header">
    <div class="d-flex align-items-center gap-3">
        <a asp-action="Index" class="back-btn"><i class="bi bi-arrow-left"></i> Назад</a>
        <h1 class="page-title"><i class="bi bi-folder-plus"></i> Новий каталог</h1>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="form-card">
            <div class="form-card-header">
                <h5><i class="bi bi-folder2" style="color:var(--yellow)"></i> Створення каталогу</h5>
            </div>
            <div class="form-card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

                    <div class="mb-4">
                        <label asp-for="Name" class="form-label">Назва каталогу</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-folder2"></i></span>
                            <input asp-for="Name" class="form-control" placeholder="my-folder" />
                        </div>
                        <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Parentfolderid" class="form-label">Батьківський каталог</label>
                        <select asp-for="Parentfolderid" class="form-select" asp-items="ViewBag.Parentfolderid">
                            <option value="">— Кореневий каталог —</option>
                        </select>
                        <div class="mt-1" style="font-size:0.8rem; color:var(--text-muted);">Залиште порожнім для кореневого рівня</div>
                    </div>

                    <hr class="divider" />
                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-action="Index" class="btn btn-outline-secondary">Скасувати</a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-folder-check"></i> Створити
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
