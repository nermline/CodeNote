@using NoteInfrastructure.Helpers
@model NoteDomain.Model.Folder

@{
    ViewData["Title"] = Model.Name;

    var subFolders = ViewData["SubFolders"] as PaginatedList<NoteDomain.Model.Folder>;
    var files      = ViewData["Files"]      as PaginatedList<NoteDomain.Model.File>;

    string BuildFolderPath(NoteDomain.Model.Folder? folder)
    {
        if (folder == null) return "~/";
        var parts = new System.Collections.Generic.List<string>();
        var cur = folder;
        while (cur != null) { parts.Insert(0, cur.Name); cur = cur.Parentfolder; }
        return "~/" + string.Join("/", parts) + "/";
    }

    string folderPath = BuildFolderPath(Model);

    int currentSubPage  = subFolders?.PageIndex  ?? 1;
    int currentFilePage = files?.PageIndex ?? 1;

    string SubUrl(int p)
    {
        return Url.Action("Details", "Folders", new { id = Model.Id, subPage = p, filePage = currentFilePage })!;
    }
    string FileUrl(int p)
    {
        return Url.Action("Details", "Folders", new { id = Model.Id, subPage = currentSubPage, filePage = p })!;
    }
}

<div class="page-header">
    <div class="d-flex align-items-center gap-3 flex-wrap">
        @if (Model.Parentfolder != null)
        {
            <a asp-action="Details" asp-route-id="@Model.Parentfolderid" class="back-btn">
                <i class="bi bi-arrow-left"></i> @Model.Parentfolder.Name
            </a>
        }
        else
        {
            <a asp-action="Index" class="back-btn">
                <i class="bi bi-arrow-left"></i> Каталоги
            </a>
        }
        <h1 class="page-title">
            <i class="bi bi-folder-fill" style="color:var(--yellow)"></i>
            @Model.Name
        </h1>
        <span class="breadcrumb-path">
            <i class="bi bi-hdd-network me-1"></i>@folderPath
        </span>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">
            <i class="bi bi-pencil"></i> Редагувати
        </a>
        <a asp-action="Delete" asp-route-id="@Model?.Id" class="btn btn-danger btn-icon" title="Видалити">
            <i class="bi bi-trash"></i>
        </a>
    </div>
</div>

<div class="row g-3">
    <!-- Subfolders -->
    <div class="col-lg-5">
        <div class="card h-100 d-flex flex-column">
            <div class="card-header-custom">
                <span class="header-title">
                    <i class="bi bi-folder2"></i> Підкаталоги
                    @if (subFolders != null && subFolders.TotalCount > 0)
                    {
                        <span class="badge badge-folder ms-1">@subFolders.TotalCount</span>
                    }
                </span>
                <a asp-action="Create" asp-route-parentFolderId="@Model.Id" class="btn btn-sm btn-outline-success">
                    <i class="bi bi-folder-plus"></i> Новий
                </a>
            </div>

            @if (subFolders != null && subFolders.Any())
            {
                <div class="card-body p-0 flex-grow-1">
                    @foreach (var subfolder in subFolders)
                    {
                        <div style="display:flex; align-items:center; justify-content:space-between; padding:0.75rem 1.1rem; border-bottom:1px solid var(--border-muted);">
                            <a asp-action="Details" asp-route-id="@subfolder.Id"
                               class="d-flex align-items-center gap-2 text-decoration-none" style="color:var(--text-primary);">
                                <i class="bi bi-folder-fill" style="color:var(--yellow);"></i>
                                <span style="font-size:0.9rem;">@subfolder.Name</span>
                            </a>
                            <div class="d-flex gap-1">
                                <a asp-action="Edit" asp-route-id="@subfolder.Id" class="btn btn-sm btn-warning btn-icon" title="Редагувати"><i class="bi bi-pencil"></i></a>
                                <a asp-action="Delete" asp-route-id="@subfolder.Id" class="btn btn-sm btn-danger btn-icon" title="Видалити"><i class="bi bi-trash"></i></a>
                            </div>
                        </div>
                    }
                </div>
                @if (subFolders.TotalPages > 1)
                {
                    <div class="pagination-bar border-top">
                        <span class="pagination-info">
                            <i class="bi bi-list-ul me-1"></i>
                            <strong>@((subFolders.PageIndex-1)*subFolders.PageSize+1)–@(Math.Min(subFolders.PageIndex*subFolders.PageSize, subFolders.TotalCount))</strong>
                            з <strong>@subFolders.TotalCount</strong>
                        </span>
                        <nav class="pagination-nav">
                            <a class="page-btn @(!subFolders.HasPreviousPage ? "disabled" : "")"
                               href="@SubUrl(subFolders.PageIndex - 1)" title="Попередня">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                            @{
                                int sRangeStart = Math.Max(1, subFolders.PageIndex - 2);
                                int sRangeCount = Math.Min(5, subFolders.TotalPages - Math.Max(0, subFolders.PageIndex - 3));
                                int sRangeEnd   = sRangeStart + sRangeCount - 1;
                            }
                            @if (sRangeStart > 1)
                            {
                                <a class="page-btn" href="@SubUrl(1)">1</a>
                                @if (sRangeStart > 2) { <span class="page-ellipsis">…</span> }
                            }
                            @foreach (var p in Enumerable.Range(sRangeStart, sRangeCount))
                            {
                                <a class="page-btn @(p == subFolders.PageIndex ? "active" : "")" href="@SubUrl(p)">@p</a>
                            }
                            @if (sRangeEnd < subFolders.TotalPages)
                            {
                                @if (sRangeEnd < subFolders.TotalPages - 1) { <span class="page-ellipsis">…</span> }
                                <a class="page-btn" href="@SubUrl(subFolders.TotalPages)">@subFolders.TotalPages</a>
                            }
                            <a class="page-btn @(!subFolders.HasNextPage ? "disabled" : "")"
                               href="@SubUrl(subFolders.PageIndex + 1)" title="Наступна">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </nav>
                    </div>
                }
            }
            else
            {
                <div class="empty-state" style="padding:2rem 1rem;">
                    <i class="bi bi-folder2-open" style="font-size:2rem;"></i>
                    <p>Немає підкаталогів</p>
                </div>
            }
        </div>
    </div>

    <!-- Files -->
    <div class="col-lg-7">
        <div class="card h-100 d-flex flex-column">
            <div class="card-header-custom">
                <span class="header-title">
                    <i class="bi bi-file-earmark-code"></i> Файли
                    @if (files != null && files.TotalCount > 0)
                    {
                        <span class="badge badge-folder ms-1">@files.TotalCount</span>
                    }
                </span>
                <a asp-controller="Files" asp-action="Create" asp-route-folderId="@Model.Id" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-plus-lg"></i> Новий файл
                </a>
            </div>

            @if (files != null && files.Any())
            {
                <div class="card-body p-0 flex-grow-1">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th class="ps-3">Назва</th>
                                <th>Опис</th>
                                <th class="text-end pe-3">Дії</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var file in files)
                            {
                                <tr>
                                    <td class="ps-3">
                                        <div class="d-flex align-items-center gap-2">
                                            <i class="bi bi-file-earmark-code" style="color:var(--accent);"></i>
                                            <a asp-controller="Files" asp-action="Details" asp-route-id="@file.Id"
                                               class="text-decoration-none" style="color:var(--text-primary); font-size:0.9rem;">
                                                @file.Name
                                            </a>
                                        </div>
                                    </td>
                                    <td style="color:var(--text-muted); font-size:0.825rem; max-width:180px;">
                                        <span class="text-truncate d-block">@(string.IsNullOrEmpty(file.Description) ? "—" : file.Description)</span>
                                    </td>
                                    <td class="text-end pe-3">
                                        <div class="d-flex gap-1 justify-content-end">
                                            <a asp-controller="Files" asp-action="Details" asp-route-id="@file.Id" class="btn btn-sm btn-outline-secondary btn-icon" title="Деталі"><i class="bi bi-eye"></i></a>
                                            <a asp-controller="Files" asp-action="Edit" asp-route-id="@file.Id" class="btn btn-sm btn-warning btn-icon" title="Редагувати"><i class="bi bi-pencil"></i></a>
                                            <a asp-controller="Files" asp-action="Delete" asp-route-id="@file.Id" class="btn btn-sm btn-danger btn-icon" title="Видалити"><i class="bi bi-trash"></i></a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                @if (files.TotalPages > 1)
                {
                    <div class="pagination-bar border-top">
                        <span class="pagination-info">
                            <i class="bi bi-list-ul me-1"></i>
                            <strong>@((files.PageIndex-1)*files.PageSize+1)–@(Math.Min(files.PageIndex*files.PageSize, files.TotalCount))</strong>
                            з <strong>@files.TotalCount</strong>
                        </span>
                        <nav class="pagination-nav">
                            <a class="page-btn @(!files.HasPreviousPage ? "disabled" : "")"
                               href="@FileUrl(files.PageIndex - 1)" title="Попередня">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                            @{
                                int fRangeStart = Math.Max(1, files.PageIndex - 2);
                                int fRangeCount = Math.Min(5, files.TotalPages - Math.Max(0, files.PageIndex - 3));
                                int fRangeEnd   = fRangeStart + fRangeCount - 1;
                            }
                            @if (fRangeStart > 1)
                            {
                                <a class="page-btn" href="@FileUrl(1)">1</a>
                                @if (fRangeStart > 2) { <span class="page-ellipsis">…</span> }
                            }
                            @foreach (var p in Enumerable.Range(fRangeStart, fRangeCount))
                            {
                                <a class="page-btn @(p == files.PageIndex ? "active" : "")" href="@FileUrl(p)">@p</a>
                            }
                            @if (fRangeEnd < files.TotalPages)
                            {
                                @if (fRangeEnd < files.TotalPages - 1) { <span class="page-ellipsis">…</span> }
                                <a class="page-btn" href="@FileUrl(files.TotalPages)">@files.TotalPages</a>
                            }
                            <a class="page-btn @(!files.HasNextPage ? "disabled" : "")"
                               href="@FileUrl(files.PageIndex + 1)" title="Наступна">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </nav>
                    </div>
                }
            }
            else
            {
                <div class="empty-state" style="padding:2rem 1rem;">
                    <i class="bi bi-file-earmark-plus" style="font-size:2rem;"></i>
                    <p>Немає файлів у цьому каталозі</p>
                </div>
            }
        </div>
    </div>
</div>
