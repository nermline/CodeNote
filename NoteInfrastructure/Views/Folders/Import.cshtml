@{
    ViewData["Title"] = "Імпорт каталогів";
}

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="bi bi-file-earmark-arrow-up"></i> Імпорт даних</h1>
        <div class="breadcrumb-path">
            <a asp-action="Index">Каталоги</a> / Імпорт
        </div>
    </div>
</div>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger mb-3">
        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <div><i class="bi bi-exclamation-triangle me-1"></i>@error.ErrorMessage</div>
        }
    </div>
}

<div class="row g-4">

    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-file-earmark-excel text-success fs-5"></i>
                <strong>Імпорт з Excel (.xlsx)</strong>
            </div>
            <div class="card-body">
                <p class="text-muted small mb-3">
                    Масовий ввід даних. Кожен аркуш — окремий каталог.
                </p>
                <div class="alert alert-light border small mb-3">
                    <strong>Структура файлу (перший рядок — заголовок):</strong>
                    <ul class="mb-0 mt-2 ps-3">
                        <li><strong>A</strong> — Назва файлу</li>
                        <li><strong>B</strong> — Опис</li>
                        <li><strong>C</strong> — Теги (через кому)</li>
                        <li><strong>D</strong> — Номер версії</li>
                        <li><strong>E</strong> — Вміст</li>
                        <li><strong>F</strong> — Журнал змін</li>
                    </ul>
                    <div class="mt-2">Якщо каталог/тег існує — прив'язується автоматично.</div>
                </div>
                <form asp-action="Import" asp-controller="Folders" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label for="fileExcelXlsx" class="form-label fw-semibold">Оберіть файл .xlsx</label>
                        <input type="file" name="file" id="fileExcelXlsx"
                               accept=".xlsx,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
                               class="form-control" required />
                        <div class="mt-1" style="font-size:0.75rem; color:var(--text-muted);">
                            <i class="bi bi-info-circle me-1"></i>Підтримується лише формат <span style="font-family:var(--font-mono); color:var(--green);">.xlsx</span>, максимум 10 МБ
                        </div>
                    </div>
                    <button type="submit" class="btn btn-success w-100">
                        <i class="bi bi-upload me-1"></i> Завантажити Excel
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-file-earmark-word text-primary fs-5"></i>
                <strong>Імпорт з Word (.docx)</strong>
                <span class="badge bg-warning text-dark ms-auto">+1 бал</span>
            </div>
            <div class="card-body">
                <p class="text-muted small mb-3">
                    Розбір структурованого звіту — підтримує документи, сформовані
                    функцією «Експорт у Word».
                </p>
                <div class="alert alert-light border small mb-3">
                    <strong>Очікувана структура:</strong>
                    <ul class="mb-0 mt-2 ps-3">
                        <li><strong>Heading 1</strong> → назва каталогу</li>
                        <li><strong>Heading 2</strong> → назва файлу</li>
                        <li><strong>Таблиця</strong> → Опис, Теги файлу</li>
                        <li><strong>▸ Версія N</strong> + таблиця → вміст версії, журнал</li>
                    </ul>
                    <div class="mt-2">Якщо каталог/файл/тег існує — дані прив'язуються до наявних.</div>
                </div>
                <form asp-action="Import" asp-controller="Folders" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label for="fileDocx" class="form-label fw-semibold">Оберіть файл .docx</label>
                        <input type="file" name="file" id="fileDocx"
                               accept=".docx,application/vnd.openxmlformats-officedocument.wordprocessingml.document"
                               class="form-control" required />
                        <div class="mt-1" style="font-size:0.75rem; color:var(--text-muted);">
                            <i class="bi bi-info-circle me-1"></i>Підтримується лише формат <span style="font-family:var(--font-mono); color:var(--accent);">.docx</span>, максимум 10 МБ
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-upload me-1"></i> Завантажити Word
                    </button>
                </form>
            </div>
        </div>
    </div>

</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Назад до каталогів
    </a>
</div>
