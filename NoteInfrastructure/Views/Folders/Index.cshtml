@model IEnumerable<NoteDomain.Model.Folder>

@{
    ViewData["Title"] = "Провідник - Каталоги";
}

<div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-secondary pb-3">
    <h4 class="mb-0 text-light"><i class="bi bi-hdd-network"></i> root/folders/</h4>
    <a asp-action="Create" class="btn btn-sm btn-outline-info"><i class="bi bi-folder-plus"></i> Створити каталог</a>
</div>

<div class="explorer-grid">
    @foreach (var item in Model)
    {
        <div class="explorer-item position-relative group">
            <a asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none text-light d-block">
                <i class="bi bi-folder-fill explorer-icon icon-folder"></i>
                <div class="text-truncate small mt-2" title="@item.Name">@item.Name</div>
            </a>
            <div class="mt-2 d-flex justify-content-center gap-3">
                <a asp-action="Edit" asp-route-id="@item.Id" class="text-warning text-decoration-none" title="Перейменувати"><i class="bi bi-pencil"></i></a>
                <a asp-action="Delete" asp-route-id="@item.Id" class="text-danger text-decoration-none" title="Видалити"><i class="bi bi-trash"></i></a>
            </div>
        </div>
    }
</div>