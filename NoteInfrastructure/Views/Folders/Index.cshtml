@using NoteInfrastructure.Helpers
@model PaginatedList<NoteDomain.Model.Folder>

@{
    ViewData["Title"] = "Провідник";
    ViewData["PaginatedList"] = Model;
    ViewData["Action"] = "Index";
    string? search = ViewData["Search"] as string;
}

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="bi bi-folder2"></i> Каталоги</h1>
        <div class="breadcrumb-path"><i class="bi bi-hdd-network me-1"></i> root / folders /</div>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-folder-plus"></i> Новий каталог
    </a>
</div>

<div class="list-search-bar mb-3">
    <form asp-action="Index" method="get" class="d-flex gap-2">
        <div class="search-input-wrap flex-grow-1">
            <i class="bi bi-search search-icon"></i>
            <input type="text" name="search" value="@search"
                   class="form-control search-input"
                   placeholder="Фільтр за назвою каталогу…" autocomplete="off" />
            @if (!string.IsNullOrWhiteSpace(search))
            {
                <a asp-action="Index" class="search-clear" title="Скинути"><i class="bi bi-x"></i></a>
            }
        </div>
        <button type="submit" class="btn btn-outline-secondary">
            <i class="bi bi-funnel"></i> Фільтр
        </button>
    </form>
</div>

@if (Model.Any())
{
    <div class="explorer-grid">
        @foreach (var item in Model)
        {
            <div class="explorer-item">
                <a asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none d-block">
                    <i class="bi bi-folder-fill explorer-icon"></i>
                    <div class="text-truncate" style="font-size:0.8125rem; color:var(--text-primary); font-weight:500;" title="@item.Name">@item.Name</div>
                    @if (item.Createdat.HasValue)
                    {
                        <div style="font-size:0.7rem; color:var(--text-muted); margin-top:0.2rem;">@item.Createdat.Value.ToString("dd.MM.yyyy")</div>
                    }
                </a>
                <div class="explorer-item-actions">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning btn-icon" title="Перейменувати">
                        <i class="bi bi-pencil"></i>
                    </a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger btn-icon" title="Видалити">
                        <i class="bi bi-trash"></i>
                    </a>
                </div>
            </div>
        }
    </div>
    @await Html.PartialAsync("_Pagination")
}
else if (!string.IsNullOrWhiteSpace(search))
{
    <div class="card">
        <div class="empty-state">
            <i class="bi bi-search"></i>
            <h5>Нічого не знайдено</h5>
            <p>За запитом «@search» каталогів не знайдено.</p>
            <a asp-action="Index" class="btn btn-outline-secondary mt-2"><i class="bi bi-x"></i> Скинути фільтр</a>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="empty-state">
            <i class="bi bi-folder2-open"></i>
            <h5>Каталогів ще немає</h5>
            <p>Створіть перший каталог, щоб організувати ваші файли.</p>
            <a asp-action="Create" class="btn btn-primary mt-2"><i class="bi bi-folder-plus"></i> Створити каталог</a>
        </div>
    </div>
}
