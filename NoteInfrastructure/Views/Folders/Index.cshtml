@model IEnumerable<NoteDomain.Model.Folder>

@{
    ViewData["Title"] = "Провідник";
}

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="bi bi-folder2"></i> Каталоги</h1>
        <div class="breadcrumb-path"><i class="bi bi-hdd-network me-1"></i> root / folders /</div>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-folder-plus"></i> Новий каталог
    </a>
</div>

@if (Model.Any())
{
    <div class="explorer-grid">
        @foreach (var item in Model)
        {
            <div class="explorer-item">
                <a asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none d-block">
                    <i class="bi bi-folder-fill explorer-icon"></i>
                    <div class="text-truncate" style="font-size:0.8125rem; color:var(--text-primary); font-weight:500;" title="@item.Name">@item.Name</div>
                    @if (item.Createdat.HasValue)
                    {
                        <div style="font-size:0.7rem; color:var(--text-muted); margin-top:0.2rem;">@item.Createdat.Value.ToString("dd.MM.yyyy")</div>
                    }
                </a>
                <div class="explorer-item-actions">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning btn-icon" title="Перейменувати">
                        <i class="bi bi-pencil"></i>
                    </a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger btn-icon" title="Видалити">
                        <i class="bi bi-trash"></i>
                    </a>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="card">
        <div class="empty-state">
            <i class="bi bi-folder2-open"></i>
            <h5>Каталогів ще немає</h5>
            <p>Створіть перший каталог, щоб організувати ваші файли.</p>
            <a asp-action="Create" class="btn btn-primary mt-2">
                <i class="bi bi-folder-plus"></i> Створити каталог
            </a>
        </div>
    </div>
}
