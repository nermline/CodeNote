@using Microsoft.AspNetCore.Identity
@model NoteInfrastructure.ViewModels.ChangeRoleViewModel
@{
    ViewData["Title"] = "Права доступу";
}

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="bi bi-person-gear"></i> Права доступу</h1>
        <div class="breadcrumb-path">
            Адмін / <a asp-action="UserList">Користувачі</a> / Права доступу
        </div>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header d-flex align-items-center gap-2" style="color:var(--text-primary, inherit)">
                <i class="bi bi-person-circle text-primary fs-5"></i>
                <strong>@Model.UserEmail</strong>
            </div>
            <div class="card-body">

                <div class="alert alert-info mb-3 small">
                    <i class="bi bi-info-circle me-1"></i>
                    Роль «admin» не можна прибрати у єдиного адміністратора системи.
                </div>

                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="userId" value="@Model.UserId" />

                    @foreach (IdentityRole role in Model.AllRoles)
                    {
                        <div class="form-check mb-2">
                            <input class="form-check-input"
                                   type="checkbox"
                                   name="roles"
                                   value="@role.Name"
                                   id="role_@role.Id"
                                   @(Model.UserRoles.Contains(role.Name!) ? "checked" : "") />
                            <label class="form-check-label" for="role_@role.Id">
                                <i class="bi bi-shield @(role.Name == "admin" ? "text-danger" : "text-secondary") me-1"></i>
                                @role.Name
                            </label>
                        </div>
                    }

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-floppy me-1"></i> Зберегти
                        </button>
                        <a asp-action="UserList" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i> Назад
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
