@model NoteInfrastructure.ViewModels.AdminResetPasswordViewModel
@{
    ViewData["Title"] = "Скидання пароля";
}

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="bi bi-key"></i> Скидання пароля</h1>
        <div class="breadcrumb-path">
            Адмін / <a asp-action="UserList">Користувачі</a> / Скидання пароля
        </div>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header d-flex align-items-center gap-2" style="color:var(--text-primary, inherit)">
                <i class="bi bi-person-circle text-primary fs-5"></i>
                <strong>@Model.UserEmail</strong>
            </div>
            <div class="card-body">

                <div class="alert alert-warning mb-3">
                    <i class="bi bi-info-circle me-2"></i>
                    Ви задаєте новий пароль для користувача. Поточний пароль не перевіряється.
                </div>

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"
                     style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                <form asp-action="ResetPassword" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="UserId" />
                    <input type="hidden" asp-for="UserEmail" />

                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label fw-semibold"></label>
                        <input asp-for="NewPassword" class="form-control" type="password"
                               autocomplete="new-password" />
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                        <div class="mt-1" style="font-size:0.75rem; color:var(--text-muted);">
                            <i class="bi bi-info-circle me-1"></i>Мінімум 6 символів, щонайменше одна цифра
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                        <input asp-for="ConfirmPassword" class="form-control" type="password"
                               autocomplete="new-password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning">
                            <i class="bi bi-floppy me-1"></i> Скинути пароль
                        </button>
                        <a asp-action="UserList" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i> Скасувати
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
