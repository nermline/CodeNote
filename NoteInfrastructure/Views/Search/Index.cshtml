@using NoteInfrastructure.Helpers
@model NoteInfrastructure.Models.SearchResultViewModel

@{
    ViewData["Title"] = string.IsNullOrWhiteSpace(Model.Query)
        ? "Глобальний пошук"
        : $"Пошук: {Model.Query}";
    bool hasQuery = !string.IsNullOrWhiteSpace(Model.Query);

    // Helper: build search URL preserving all page params except the changed one
    int filesPage   = Model.Files?.PageIndex   ?? 1;
    int foldersPage = Model.Folders?.PageIndex ?? 1;
    int commitsPage = Model.Commits?.PageIndex ?? 1;
    int tagsPage    = Model.Tags?.PageIndex    ?? 1;

    string SearchUrl(string changedParam, int page) => Url.Action("Index", "Search", new
    {
        q           = Model.Query,
        filesPage   = changedParam == "filesPage"   ? page : filesPage,
        foldersPage = changedParam == "foldersPage" ? page : foldersPage,
        commitsPage = changedParam == "commitsPage" ? page : commitsPage,
        tagsPage    = changedParam == "tagsPage"    ? page : tagsPage,
    })!;
}

@functions {
    (int start, int count, int end) CalcRange(int pageIndex, int totalPages)
    {
        int s = Math.Max(1, pageIndex - 2);
        int c = Math.Min(5, totalPages - Math.Max(0, pageIndex - 3));
        return (s, c, s + c - 1);
    }
}

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="bi bi-search"></i> Глобальний пошук</h1>
        <div class="breadcrumb-path"><i class="bi bi-hdd-network me-1"></i> root / search /</div>
    </div>
</div>

<div class="global-search-wrap mb-4">
    <form asp-action="Index" method="get">
        <div class="global-search-box">
            <i class="bi bi-search global-search-icon"></i>
            <input type="text" name="q" value="@Model.Query"
                   class="global-search-input"
                   placeholder="Пошук по файлах, каталогах, комітах та тегах…"
                   autofocus autocomplete="off" />
            @if (hasQuery)
            {
                <a asp-action="Index" class="global-search-clear" title="Очистити"><i class="bi bi-x-lg"></i></a>
            }
            <button type="submit" class="global-search-btn">
                <i class="bi bi-arrow-return-left"></i>
            </button>
        </div>
        <div class="search-hint">Пошук виконується по: назвах файлів, папок, номерах версій, changelog та тегах</div>
    </form>
</div>

@if (hasQuery)
{
    if (Model.TotalCount == 0)
    {
        <div class="card">
            <div class="empty-state">
                <i class="bi bi-binoculars"></i>
                <h5>Нічого не знайдено</h5>
                <p>За запитом «@Model.Query» результатів не знайдено. Спробуйте інший запит.</p>
            </div>
        </div>
    }
    else
    {
        <div class="search-summary mb-3">
            <i class="bi bi-check-circle-fill me-2" style="color:var(--green);"></i>
            Знайдено <strong>@Model.TotalCount</strong> результат(ів) за запитом
            <span class="search-query-badge">@Model.Query</span>
        </div>

        @if (Model.Files != null && Model.Files.TotalCount > 0)
        {
            <div class="search-section">
                <div class="search-section-header">
                    <i class="bi bi-file-earmark-code" style="color:var(--accent);"></i>
                    Файли
                    <span class="search-count-badge">@Model.Files.TotalCount</span>
                </div>
                <div class="card">
                    <div class="card-body p-0">
                        <table class="table table-hover mb-0">
                            <tbody>
                                @foreach (var f in Model.Files)
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="file-icon-wrap"><i class="bi bi-file-earmark-code"></i></div>
                                                <div>
                                                    <a asp-controller="Files" asp-action="Details" asp-route-id="@f.Id"
                                                       class="text-decoration-none fw-medium" style="color:var(--text-primary);">
                                                        @f.Name
                                                    </a>
                                                    @if (f.Folder != null)
                                                    {
                                                        <div style="font-size:0.75rem; color:var(--text-muted); font-family:var(--font-mono);">
                                                            <i class="bi bi-folder2 me-1"></i>@f.Folder.Name
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            @if (f.Tags != null && f.Tags.Any())
                                            {
                                                foreach (var t in f.Tags.Take(3))
                                                { <span class="badge badge-tag me-1">@t.Name</span> }
                                            }
                                        </td>
                                        <td style="color:var(--text-muted); font-size:0.8rem; font-family:var(--font-mono);">
                                            @(f.Createdat.HasValue ? f.Createdat.Value.ToString("dd.MM.yyyy") : "—")
                                        </td>
                                        <td class="text-end pe-4">
                                            <a asp-controller="Files" asp-action="Details" asp-route-id="@f.Id"
                                               class="btn btn-sm btn-outline-secondary btn-icon" title="Відкрити">
                                                <i class="bi bi-arrow-right"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    @if (Model.Files.TotalPages > 1)
                    {
                        var (fS, fC, fE) = CalcRange(filesPage, Model.Files.TotalPages);
                        <div class="pagination-bar border-top">
                            <span class="pagination-info">
                                <strong>@((filesPage-1)*10+1)–@(Math.Min(filesPage*10, Model.Files.TotalCount))</strong>
                                з <strong>@Model.Files.TotalCount</strong>
                            </span>
                            <nav class="pagination-nav">
                                <a class="page-btn @(!Model.Files.HasPreviousPage ? "disabled" : "")" href="@SearchUrl("filesPage", filesPage-1)"><i class="bi bi-chevron-left"></i></a>
                                @if (fS > 1) { <a class="page-btn" href="@SearchUrl("filesPage",1)">1</a> @if(fS>2){<span class="page-ellipsis">…</span>} }
                                @foreach (var p in Enumerable.Range(fS, fC)) { <a class="page-btn @(p==filesPage?"active":"")" href="@SearchUrl("filesPage",p)">@p</a> }
                                @if (fE < Model.Files.TotalPages) { @if(fE<Model.Files.TotalPages-1){<span class="page-ellipsis">…</span>} <a class="page-btn" href="@SearchUrl("filesPage",Model.Files.TotalPages)">@Model.Files.TotalPages</a> }
                                <a class="page-btn @(!Model.Files.HasNextPage ? "disabled" : "")" href="@SearchUrl("filesPage", filesPage+1)"><i class="bi bi-chevron-right"></i></a>
                            </nav>
                        </div>
                    }
                </div>
            </div>
        }

        @if (Model.Folders != null && Model.Folders.TotalCount > 0)
        {
            <div class="search-section">
                <div class="search-section-header">
                    <i class="bi bi-folder-fill" style="color:var(--yellow);"></i>
                    Каталоги
                    <span class="search-count-badge">@Model.Folders.TotalCount</span>
                </div>
                <div class="search-folders-grid">
                    @foreach (var folder in Model.Folders)
                    {
                        <a asp-controller="Folders" asp-action="Details" asp-route-id="@folder.Id"
                           class="search-folder-card text-decoration-none">
                            <i class="bi bi-folder-fill" style="font-size:1.5rem; color:var(--yellow);"></i>
                            <div class="fw-medium" style="color:var(--text-primary); font-size:0.875rem;">@folder.Name</div>
                            @if (folder.Createdat.HasValue)
                            {
                                <div style="font-size:0.7rem; color:var(--text-muted);">@folder.Createdat.Value.ToString("dd.MM.yyyy")</div>
                            }
                        </a>
                    }
                </div>
                @if (Model.Folders.TotalPages > 1)
                {
                    var (fdS, fdC, fdE) = CalcRange(foldersPage, Model.Folders.TotalPages);
                    <div class="pagination-bar mt-2">
                        <span class="pagination-info">
                            <strong>@((foldersPage-1)*10+1)–@(Math.Min(foldersPage*10, Model.Folders.TotalCount))</strong>
                            з <strong>@Model.Folders.TotalCount</strong>
                        </span>
                        <nav class="pagination-nav">
                            <a class="page-btn @(!Model.Folders.HasPreviousPage ? "disabled" : "")" href="@SearchUrl("foldersPage", foldersPage-1)"><i class="bi bi-chevron-left"></i></a>
                            @if (fdS > 1) { <a class="page-btn" href="@SearchUrl("foldersPage",1)">1</a> @if(fdS>2){<span class="page-ellipsis">…</span>} }
                            @foreach (var p in Enumerable.Range(fdS, fdC)) { <a class="page-btn @(p==foldersPage?"active":"")" href="@SearchUrl("foldersPage",p)">@p</a> }
                            @if (fdE < Model.Folders.TotalPages) { @if(fdE<Model.Folders.TotalPages-1){<span class="page-ellipsis">…</span>} <a class="page-btn" href="@SearchUrl("foldersPage",Model.Folders.TotalPages)">@Model.Folders.TotalPages</a> }
                            <a class="page-btn @(!Model.Folders.HasNextPage ? "disabled" : "")" href="@SearchUrl("foldersPage", foldersPage+1)"><i class="bi bi-chevron-right"></i></a>
                        </nav>
                    </div>
                }
            </div>
        }

        @if (Model.Commits != null && Model.Commits.TotalCount > 0)
        {
            <div class="search-section">
                <div class="search-section-header">
                    <i class="bi bi-git" style="color:var(--green);"></i>
                    Коміти
                    <span class="search-count-badge">@Model.Commits.TotalCount</span>
                </div>
                <div class="card">
                    <div class="card-body p-0">
                        <table class="table table-hover mb-0">
                            <tbody>
                                @foreach (var c in Model.Commits)
                                {
                                    <tr>
                                        <td class="ps-4" style="width:100px;">
                                            <span class="badge badge-version">v@(c.Versionnumber)</span>
                                        </td>
                                        <td>
                                            @if (c.File != null)
                                            {
                                                <div class="d-flex align-items-center gap-2">
                                                    <i class="bi bi-file-earmark-code" style="color:var(--accent); font-size:0.85rem;"></i>
                                                    <span style="font-size:0.875rem;">@c.File.Name</span>
                                                </div>
                                            }
                                        </td>
                                        <td style="color:var(--text-muted); font-size:0.825rem; max-width:220px;">
                                            <span class="text-truncate d-block">
                                                @(string.IsNullOrEmpty(c.Changelog) ? "—" : c.Changelog)
                                            </span>
                                        </td>
                                        <td style="color:var(--text-muted); font-size:0.8rem; font-family:var(--font-mono);">
                                            @(c.Createdat.HasValue ? c.Createdat.Value.ToString("dd.MM.yyyy HH:mm") : "—")
                                        </td>
                                        <td class="text-end pe-4">
                                            <a asp-controller="Fileversions" asp-action="Details" asp-route-id="@c.Id"
                                               class="btn btn-sm btn-outline-secondary btn-icon" title="Відкрити">
                                                <i class="bi bi-arrow-right"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    @if (Model.Commits.TotalPages > 1)
                    {
                        var (cS, cC, cE) = CalcRange(commitsPage, Model.Commits.TotalPages);
                        <div class="pagination-bar border-top">
                            <span class="pagination-info">
                                <strong>@((commitsPage-1)*10+1)–@(Math.Min(commitsPage*10, Model.Commits.TotalCount))</strong>
                                з <strong>@Model.Commits.TotalCount</strong>
                            </span>
                            <nav class="pagination-nav">
                                <a class="page-btn @(!Model.Commits.HasPreviousPage ? "disabled" : "")" href="@SearchUrl("commitsPage", commitsPage-1)"><i class="bi bi-chevron-left"></i></a>
                                @if (cS > 1) { <a class="page-btn" href="@SearchUrl("commitsPage",1)">1</a> @if(cS>2){<span class="page-ellipsis">…</span>} }
                                @foreach (var p in Enumerable.Range(cS, cC)) { <a class="page-btn @(p==commitsPage?"active":"")" href="@SearchUrl("commitsPage",p)">@p</a> }
                                @if (cE < Model.Commits.TotalPages) { @if(cE<Model.Commits.TotalPages-1){<span class="page-ellipsis">…</span>} <a class="page-btn" href="@SearchUrl("commitsPage",Model.Commits.TotalPages)">@Model.Commits.TotalPages</a> }
                                <a class="page-btn @(!Model.Commits.HasNextPage ? "disabled" : "")" href="@SearchUrl("commitsPage", commitsPage+1)"><i class="bi bi-chevron-right"></i></a>
                            </nav>
                        </div>
                    }
                </div>
            </div>
        }

        @if (Model.Tags != null && Model.Tags.TotalCount > 0)
        {
            <div class="search-section">
                <div class="search-section-header">
                    <i class="bi bi-tag-fill" style="color:var(--purple);"></i>
                    Теги
                    <span class="search-count-badge">@Model.Tags.TotalCount</span>
                </div>
                <div class="search-tags-grid">
                    @foreach (var tag in Model.Tags)
                    {
                        <a asp-controller="Tags" asp-action="Details" asp-route-id="@tag.Id"
                           class="search-tag-card text-decoration-none">
                            <i class="bi bi-tag-fill" style="color:var(--purple);"></i>
                            <span class="fw-medium" style="color:var(--text-primary);">@tag.Name</span>
                            @if (tag.Files != null && tag.Files.Any())
                            {
                                <span class="badge badge-folder ms-1">@tag.Files.Count()</span>
                            }
                        </a>
                    }
                </div>
                @if (Model.Tags.TotalPages > 1)
                {
                    var (tS, tC, tE) = CalcRange(tagsPage, Model.Tags.TotalPages);
                    <div class="pagination-bar mt-2">
                        <span class="pagination-info">
                            <strong>@((tagsPage-1)*10+1)–@(Math.Min(tagsPage*10, Model.Tags.TotalCount))</strong>
                            з <strong>@Model.Tags.TotalCount</strong>
                        </span>
                        <nav class="pagination-nav">
                            <a class="page-btn @(!Model.Tags.HasPreviousPage ? "disabled" : "")" href="@SearchUrl("tagsPage", tagsPage-1)"><i class="bi bi-chevron-left"></i></a>
                            @if (tS > 1) { <a class="page-btn" href="@SearchUrl("tagsPage",1)">1</a> @if(tS>2){<span class="page-ellipsis">…</span>} }
                            @foreach (var p in Enumerable.Range(tS, tC)) { <a class="page-btn @(p==tagsPage?"active":"")" href="@SearchUrl("tagsPage",p)">@p</a> }
                            @if (tE < Model.Tags.TotalPages) { @if(tE<Model.Tags.TotalPages-1){<span class="page-ellipsis">…</span>} <a class="page-btn" href="@SearchUrl("tagsPage",Model.Tags.TotalPages)">@Model.Tags.TotalPages</a> }
                            <a class="page-btn @(!Model.Tags.HasNextPage ? "disabled" : "")" href="@SearchUrl("tagsPage", tagsPage+1)"><i class="bi bi-chevron-right"></i></a>
                        </nav>
                    </div>
                }
            </div>
        }
    }
}
else
{
    <div class="search-tips">
        <div class="search-tips-header"><i class="bi bi-lightbulb me-2" style="color:var(--yellow);"></i>Що можна шукати?</div>
        <div class="search-tips-grid">
            <div class="search-tip-item">
                <div class="search-tip-icon" style="background:rgba(88,166,255,.1); color:var(--accent);">
                    <i class="bi bi-file-earmark-code"></i>
                </div>
                <div>
                    <div class="fw-medium" style="font-size:0.875rem;">Файли</div>
                    <div style="font-size:0.8rem; color:var(--text-muted);">Пошук за назвою файлу</div>
                </div>
            </div>
            <div class="search-tip-item">
                <div class="search-tip-icon" style="background:rgba(210,153,34,.1); color:var(--yellow);">
                    <i class="bi bi-folder-fill"></i>
                </div>
                <div>
                    <div class="fw-medium" style="font-size:0.875rem;">Каталоги</div>
                    <div style="font-size:0.8rem; color:var(--text-muted);">Пошук за назвою каталогу</div>
                </div>
            </div>
            <div class="search-tip-item">
                <div class="search-tip-icon" style="background:rgba(63,185,80,.1); color:var(--green);">
                    <i class="bi bi-git"></i>
                </div>
                <div>
                    <div class="fw-medium" style="font-size:0.875rem;">Коміти</div>
                    <div style="font-size:0.8rem; color:var(--text-muted);">За версією, changelog або файлом</div>
                </div>
            </div>
            <div class="search-tip-item">
                <div class="search-tip-icon" style="background:rgba(188,140,255,.1); color:var(--purple);">
                    <i class="bi bi-tag-fill"></i>
                </div>
                <div>
                    <div class="fw-medium" style="font-size:0.875rem;">Теги</div>
                    <div style="font-size:0.8rem; color:var(--text-muted);">Пошук за назвою тегу</div>
                </div>
            </div>
        </div>
    </div>
}
