@model ErrorViewModel

@{
    ViewData["Title"] = "Помилка";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 text-center">
        <div style="font-size:5rem; font-family:var(--font-mono); font-weight:700; color:var(--red); opacity:0.3; line-height:1;">500</div>
        <h2 style="color:var(--text-primary); margin-bottom:0.5rem;">Щось пішло не так</h2>
        <p style="color:var(--text-muted); font-size:0.9rem; max-width:360px; margin: 0 auto 1.5rem;">
            Виникла неочікувана помилка. Спробуйте ще раз або поверніться на головну.
        </p>
        @if (Model?.ShowRequestId == true)
        {
            <div style="font-family:var(--font-mono); font-size:0.75rem; color:var(--text-muted); background:var(--bg-elevated); border:1px solid var(--border); border-radius:var(--radius-md); padding:0.5rem 1rem; display:inline-block; margin-bottom:1.5rem;">
                Request ID: <span style="color:var(--accent);">@Model.RequestId</span>
            </div>
        }
        <div>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                <i class="bi bi-house-fill"></i> На головну
            </a>
        </div>
    </div>
</div>
