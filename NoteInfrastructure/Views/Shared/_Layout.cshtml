<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — CodeNote</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <nav class="app-navbar navbar navbar-expand-sm">
        <div class="container-fluid">
            <a class="navbar-brand-custom" asp-controller="Home" asp-action="Index">
                <span class="brand-icon"><i class="bi bi-code-slash"></i></span>
                CodeNote
            </a>

            <button class="navbar-toggler-custom d-sm-none" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-expanded="false">
                <i class="bi bi-list"></i>
            </button>

            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="nav-links">
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Folders" ? "active" : "")"
                           asp-controller="Folders" asp-action="Index">
                            <i class="bi bi-folder2"></i> Папки
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Files" ? "active" : "")"
                           asp-controller="Files" asp-action="Index">
                            <i class="bi bi-file-earmark-code"></i> Файли
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Tags" ? "active" : "")"
                           asp-controller="Tags" asp-action="Index">
                            <i class="bi bi-tags"></i> Теги
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Fileversions" ? "active" : "")"
                           asp-controller="Fileversions" asp-action="Index">
                            <i class="bi bi-git"></i> Версії
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Statistics" ? "active" : "")"
                           asp-controller="Statistics" asp-action="Index">
                            <i class="bi bi-bar-chart-line"></i> Статистика
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="page-container">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
