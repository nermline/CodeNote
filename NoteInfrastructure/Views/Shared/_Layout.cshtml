<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CodeNote</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="app-container">
        <aside class="sidebar">
            <a class="sidebar-header" asp-area="" asp-controller="Home" asp-action="Index">
                <i class="bi bi-code-square me-2 text-info"></i>CodeNote
            </a>
            <div class="mt-3 px-3 pb-2 text-uppercase text-muted" style="font-size: 0.75rem;">
                Провідник
            </div>
            <ul class="nav flex-column sidebar-nav">
                <li class="nav-item">
                    <a class="nav-link" asp-area="" asp-controller="Folders" asp-action="Index">
                        <i class="bi bi-chevron-right me-1" style="font-size: 0.7rem;"></i>
                        <i class="bi bi-folder2-open me-2 text-warning"></i> Каталоги
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-area="" asp-controller="Files" asp-action="Index">
                        <i class="bi bi-chevron-right me-1" style="font-size: 0.7rem;"></i>
                        <i class="bi bi-files me-2 text-info"></i> Усі Файли
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-area="" asp-controller="Tags" asp-action="Index">
                        <i class="bi bi-chevron-right me-1" style="font-size: 0.7rem;"></i>
                        <i class="bi bi-tags me-2 text-success"></i> Теги
                    </a>
                </li>
            </ul>
        </aside>

        <main class="main-content">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>