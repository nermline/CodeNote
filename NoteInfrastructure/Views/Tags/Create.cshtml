@model NoteDomain.Model.Tag

@{
    ViewData["Title"] = "Новий тег";
}

<div class="page-header">
    <div class="d-flex align-items-center gap-3">
        <a asp-action="Index" class="back-btn"><i class="bi bi-arrow-left"></i> Назад</a>
        <h1 class="page-title"><i class="bi bi-tag-fill"></i> Новий тег</h1>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-5">
        <div class="form-card">
            <div class="form-card-header">
                <h5><i class="bi bi-tag-fill" style="color:var(--purple)"></i> Створення тегу</h5>
            </div>
            <div class="form-card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

                    <div class="mb-4">
                        <label asp-for="Name" class="form-label">Назва тегу</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-tag-fill" style="color:var(--purple)"></i></span>
                            <input asp-for="Name" class="form-control" placeholder="frontend, backend, api…" />
                        </div>
                        <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <hr class="divider" />
                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-action="Index" class="btn btn-outline-secondary">Скасувати</a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg"></i> Створити
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
