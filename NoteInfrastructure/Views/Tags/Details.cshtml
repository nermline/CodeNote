@model NoteDomain.Model.Tag

@{
    ViewData["Title"] = "Тег — " + Model.Name;
}

<div class="page-header">
    <div class="d-flex align-items-center gap-3">
        <a asp-action="Index" class="back-btn"><i class="bi bi-arrow-left"></i> Теги</a>
        <h1 class="page-title">
            <i class="bi bi-tag-fill" style="color:var(--purple)"></i>
            @Model.Name
        </h1>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">
            <i class="bi bi-pencil"></i> Редагувати
        </a>
        <a asp-action="Delete" asp-route-id="@Model?.Id" class="btn btn-danger btn-icon" title="Видалити">
            <i class="bi bi-trash"></i>
        </a>
    </div>
</div>

<div class="card">
    <div class="card-header-custom">
        <span class="header-title"><i class="bi bi-file-earmark-code"></i> Файли з цим тегом</span>
        <span class="badge badge-tag">@(Model.Files?.Count() ?? 0) файл(ів)</span>
    </div>

    @if (Model.Files != null && Model.Files.Any())
    {
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Назва файлу</th>
                        <th>Опис</th>
                        <th class="text-end pe-4">Перейти</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var file in Model.Files)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="file-icon-wrap">
                                        <i class="bi bi-file-earmark-code"></i>
                                    </div>
                                    <span class="fw-medium" style="font-size:0.9rem;">@file.Name</span>
                                </div>
                            </td>
                            <td style="color:var(--text-muted); font-size:0.825rem;">
                                @(string.IsNullOrEmpty(file.Description) ? "—" : file.Description)
                            </td>
                            <td class="text-end pe-4">
                                <a asp-controller="Files" asp-action="Details" asp-route-id="@file.Id"
                                   class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-arrow-right"></i> Відкрити
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state">
            <i class="bi bi-file-earmark-x"></i>
            <h5>Немає файлів з цим тегом</h5>
            <p>Прив'яжіть цей тег до файлів через редагування файлу.</p>
        </div>
    }
</div>
