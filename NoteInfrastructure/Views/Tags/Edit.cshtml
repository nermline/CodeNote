@model NoteDomain.Model.Tag

@{
    ViewData["Title"] = "Редагування тегу — " + Model.Name;
}

<div class="page-header">
    <div class="d-flex align-items-center gap-3">
        <a asp-action="Index" class="back-btn"><i class="bi bi-arrow-left"></i> Назад</a>
        <h1 class="page-title"><i class="bi bi-pencil-square"></i> Редагування тегу</h1>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-5">
        <div class="form-card">
            <div class="form-card-header">
                <h5>
                    <i class="bi bi-tag-fill" style="color:var(--purple)"></i>
                    <span class="mono-path">@Model.Name</span>
                </h5>
            </div>
            <div class="form-card-body">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-4">
                        <label asp-for="Name" class="form-label">Назва тегу</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-tag-fill" style="color:var(--purple)"></i></span>
                            <input asp-for="Name" class="form-control" />
                        </div>
                        <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <hr class="divider" />
                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-action="Index" class="btn btn-outline-secondary">Скасувати</a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-floppy"></i> Зберегти
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
