@model IEnumerable<NoteDomain.Model.Tag>

@{
    ViewData["Title"] = "Теги";
}

<div class="page-header">
    <div>
        <h1 class="page-title"><i class="bi bi-tags"></i> Теги</h1>
        <div class="breadcrumb-path"><i class="bi bi-hdd-network me-1"></i> root / tags /</div>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-tag-fill"></i> Новий тег
    </a>
</div>

@if (Model.Any())
{
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Тег</th>
                        <th>Файлів</th>
                        <th class="text-end pe-4">Дії</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="tag-icon-wrap">
                                        <i class="bi bi-tag-fill"></i>
                                    </div>
                                    <a asp-action="Details" asp-route-id="@item.Id"
                                       class="text-decoration-none fw-medium" style="color:var(--text-primary);">
                                        @item.Name
                                    </a>
                                </div>
                            </td>
                            <td>
                                @if (item.Files != null && item.Files.Any())
                                {
                                    <span class="badge badge-folder">@item.Files.Count() файл(ів)</span>
                                }
                                else
                                {
                                    <span style="color:var(--text-muted); font-size:0.8rem;">—</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-flex gap-1 justify-content-end">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary btn-icon" title="Деталі">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning btn-icon" title="Редагувати">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger btn-icon" title="Видалити">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="empty-state">
            <i class="bi bi-tags"></i>
            <h5>Тегів ще немає</h5>
            <p>Створіть перший тег для класифікації ваших файлів.</p>
            <a asp-action="Create" class="btn btn-primary mt-2">
                <i class="bi bi-tag-fill"></i> Новий тег
            </a>
        </div>
    </div>
}
